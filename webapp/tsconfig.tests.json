{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "incremental": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "./.test-dist",
    "sourceMap": false,
    "target": "ES2022"
  },
    "include": [
    "tests/**/*.ts",
    "lib/auth/**/*.ts",
    "lib/errors/**/*.ts",
    "lib/marketing/**/*.ts",
    "lib/tenant-admin/**/*.ts",
    "lib/security/**/*.ts",
    "lib/services/**/*.ts",
    "lib/validators/**/*.ts"
  ]
}
