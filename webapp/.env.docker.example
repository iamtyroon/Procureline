# Private Docker handoff file: copy to .env.docker.local and do not commit it.
# Set these values to the shared Convex development deployment.
CONVEX_DEPLOYMENT=dev:your-shared-deployment
NEXT_PUBLIC_CONVEX_URL=https://your-shared-deployment.convex.cloud
CONVEX_SITE_URL=https://your-shared-deployment.convex.site
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-shared-deployment.convex.site

NEXT_PUBLIC_APP_URL=http://localhost:3000
LOCAL_NESTJS_URL=http://nestjs:4001

# These must match the values configured in the shared Convex deployment.
AUTH_EMAIL_TRANSPORT=dev_inbox
AUTH_DEV_INBOX_SECRET=replace-me-shared-dev-email-secret

# These must match the shared NestJS and Convex service bridge values.
PROCURELINE_SERVICE_JWT_SECRET=replace-me-shared-service-jwt-secret
PROCURELINE_CONVEX_SYNC_SECRET=replace-me-shared-convex-sync-secret
