# Convex
# Your Convex deployment URL (get this after running `npx convex dev`)
CONVEX_DEPLOYMENT=dev:procureline-123
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex Auth - Required for password authentication
# This is your Convex Site URL (not the same as CONVEX_URL)
# Get this from your Convex dashboard or after running `npx convex dev`
CONVEX_SITE_URL=https://your-deployment.convex.site
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NestJS external services bridge
NESTJS_URL=http://localhost:4001
PROCURELINE_SERVICE_JWT_SECRET=replace-me
PROCURELINE_CONVEX_SYNC_SECRET=replace-me

# Optional: For production deployment
# CONVEX_DEPLOY_KEY=

# Optional: Resend API Key (for email verification and password reset)
# AUTH_RESEND_KEY=re_xxxxxxxxxxxxxxxx
# AUTH_RESET_RESEND_FROM=Procureline <security@your-domain.com>
# AUTH_PLATFORM_ADMIN_RESEND_FROM=Procureline <platform-security@your-domain.com>

# Optional: Platform Admin security secrets
# PA_DASH_ACCESS_TOKEN_SECRET=replace-me
# PLATFORM_ADMIN_CTX_TOKEN_SECRET=replace-me
# IP_HASH_SALT=replace-me
